#!/bin/bash

set -e

QEMU_VERSION_OUTPUT=$(qemu-system-x86_64 --version | head -n 1)
QEMU_VERSION=$(echo "$QEMU_VERSION_OUTPUT" | awk '{print $4}')

if [[ -z "$QEMU_VERSION" ]]; then
    echo "Failed to parse QEMU version from output: $QEMU_VERSION_OUTPUT"
    exit 1
fi

echo "Detected QEMU version: $QEMU_VERSION"

if [[ -d qemu/.git ]]; then
    echo "Using existing qemu repo"
    cd qemu
    git fetch origin --tags
    git fetch origin --tags
    git reset --hard
    git clean -fdx
else
    echo "Cloning qemu repo"
    git clone https://gitlab.com/qemu-project/qemu.git
    cd qemu
fi

if git rev-parse "v$QEMU_VERSION" >/dev/null 2>&1; then
    git checkout "v$QEMU_VERSION"
else
    echo "Tag v$QEMU_VERSION not found. Showing available tags:"
    git tag -l | tail -n 10
    exit 1
fi

git apply ../changes.patch

export CFLAGS="-O3 -pipe -march=native -mtune=native -fomit-frame-pointer -flto=auto -fno-semantic-interposition"
export CXXFLAGS="$CFLAGS"
export LDFLAGS="-flto=auto -Wl,-O2 -Wl,--as-needed"

./configure \
  --target-list=x86_64-softmmu \
  --enable-kvm \
  --enable-linux-aio \
  --disable-werror \
  --disable-debug-info \
  --enable-lto \
  --extra-cflags="-O3 -pipe -march=native -mtune=native -fomit-frame-pointer -flto=auto -fno-semantic-interposition" \
  --prefix=/usr

make -j$(nproc)
sudo make install
cd ..

echo "Installing dkms module to disable hypercall"
cd kvm-hypercall-patch
sudo dkms install .
echo "To disable hypercall (vmmcall and vmcall) load kvm-hypercall-patch module by using modprobe, or you could do it automatically on boot in /etc/modules-load.d"
